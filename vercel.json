{
  "devCommand": "vite --port $PORT",
  "crons": [{
    "path": "/api/campaigns/cron",
    "schedule": "*/15 * * * *"
  }],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

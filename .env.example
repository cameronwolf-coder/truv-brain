# ============================================
# Truv Brain — Environment Variables
# ============================================
# Copy to .env and fill in real values.
# .mcp.json also needs matching values for MCP server child processes.

# --- CRM & Outreach ---
HUBSPOT_API_TOKEN=your-hubspot-private-app-token
SENDGRID_API_KEY=your-sendgrid-api-key
SMARTLEAD_API_KEY=your-smartlead-api-key

# --- AI / LLM ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
GEMINI_API_KEY=your-gemini-api-key

# --- Enrichment ---
APOLLO_API_KEY=your-apollo-api-key

# --- Data & Scraping ---
FIRECRAWL_API_KEY=your-firecrawl-api-key

# --- Messaging ---
KNOCK_SERVICE_TOKEN=your-knock-service-token

# --- Google Service Account (Sheets integration) ---
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# --- Ad Platforms ---
# Meta (API export — no browser needed)
META_ACCESS_TOKEN=your-meta-access-token
META_APP_SECRET=your-meta-app-secret
META_APP_ID=your-meta-app-id
META_AD_ACCOUNT_ID=act_123456789

# Google Ads (API export — requires OAuth, falls back to browser)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# LinkedIn Ads (API export — requires OAuth app, falls back to browser)
LINKEDIN_ADS_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ADS_ACCOUNT_ID=your-linkedin-ad-account-id

# --- Truv Product API (gov demo) ---
TRUV_CLIENT_ID=your-truv-client-id
TRUV_SECRET=your-truv-secret
TRUV_BASE_URL=https://prod.truv.com/v1
